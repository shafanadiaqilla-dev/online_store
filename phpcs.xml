<?xml version="1.0"?>
<ruleset name="Laravel Online Store Ruleset">
    <description>PSR-2 Coding Standard for Laravel Online Store</description>
    
    <!-- Enforce PSR-2 Coding Standard -->
    <rule ref="PSR2"/>
    
    <!-- Paths to scan -->
    <file>app</file>
    <file>config</file>
    <file>database</file>
    <file>routes</file>
    <file>tests</file>
    
    <!-- Directories and patterns to exclude -->
    <exclude-pattern>bootstrap/cache/*</exclude-pattern>
    <exclude-pattern>public/*</exclude-pattern>
    <exclude-pattern>storage/*</exclude-pattern>
    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>*.blade.php</exclude-pattern>
    
    <!-- Show progress, colors, and sniff codes -->
    <arg value="p"/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
</ruleset>
